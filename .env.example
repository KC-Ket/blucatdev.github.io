# Environment Configuration Example
# Copy this file to .env and fill in actual values
# NEVER commit .env to version control - it's in .gitignore

# Cloudflare/Wrangler Configuration
# WRANGLER_API_TOKEN=your_cloudflare_api_token_here
# WRANGLER_ACCOUNT_ID=your_cloudflare_account_id_here

# Analytics (if using)
# ANALYTICS_ID=your_analytics_id

# Contact/Email (if implementing contact form)
# CONTACT_EMAIL=contact@blucatdev.com
# SECURITY_EMAIL=security@blucatdev.com

# Third-party API Keys (if needed)
# EXTERNAL_API_KEY=your_api_key_here

# Build Environment
# NODE_ENV=production
