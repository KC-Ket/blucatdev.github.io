---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const items = await getCollection('software', ({ data }) => !data.draft);
  return items.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
---
<BaseLayout title={item.data.title} description={item.data.summary} image={item.data.capsuleImage} current="software">
  <div class="page-header">
    <div class="section-label">{item.data.genre || 'Software'}</div>
    <h1>{item.data.title}</h1>
    <p>{item.data.summary}</p>
    <div style="margin-top:1rem;display:flex;gap:0.6rem;flex-wrap:wrap;align-items:center;">
      <span class={`tag ${item.data.status === 'Released' ? 'tag-silver' : 'tag-wip'}`}>{item.data.status}</span>
      {item.data.platforms.map((p) => <span class="platform-pill">{p}</span>)}
    </div>
    <div style="margin-top:1.25rem;display:flex;gap:0.75rem;flex-wrap:wrap;">
      {item.data.storeUrl && (
        <a class="btn btn-primary" href={item.data.storeUrl} target="_blank" rel="noopener noreferrer">Download / View</a>
      )}
      {item.data.itchUrl && (
        <a class="btn btn-secondary" href={item.data.itchUrl} target="_blank" rel="noopener noreferrer">View on itch.io</a>
      )}
    </div>
  </div>

  <section class="section">
    {item.data.capsuleImage && (
      <img src={item.data.capsuleImage} alt={`${item.data.title} capsule art`} style="width:100%;max-width:600px;border-radius:var(--radius-md);border:1px solid var(--border);margin-bottom:2rem;" />
    )}

    {item.data.youtubeId && (
      <div style="position:relative;width:100%;max-width:800px;aspect-ratio:16/9;margin-bottom:2rem;border-radius:var(--radius-md);overflow:hidden;border:1px solid var(--border);">
        <iframe
          style="position:absolute;inset:0;width:100%;height:100%;"
          src={`https://www.youtube.com/embed/${item.data.youtubeId}`}
          title={`${item.data.title} video`}
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    )}

    <div class="about-story">
      <Content />
    </div>

    <div style="margin-top:2rem;">
      <a class="btn btn-secondary btn-sm" href="/software/">← Back to Software</a>
    </div>
  </section>
</BaseLayout>
