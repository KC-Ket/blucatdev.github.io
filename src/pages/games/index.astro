---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allGames = (await getCollection('games', ({ data }) => !data.draft));

// Organize by status and category - with default sorting: featured (ascending), then alphabetical
const sortGamesDefault = (games: typeof allGames) => {
  const featured = games.filter(g => g.data.featured).sort((a, b) => a.data.featuredOrder - b.data.featuredOrder);
  const notFeatured = games.filter(g => !g.data.featured).sort((a, b) => a.data.title.localeCompare(b.data.title));
  return [...featured, ...notFeatured];
};

const released = sortGamesDefault(allGames.filter((g) => g.data.status === 'Released' && !g.data.category));
const inDevelopment = sortGamesDefault(allGames.filter((g) => g.data.status === 'In Development' && !g.data.category));
const unreleased = sortGamesDefault(allGames.filter((g) => g.data.status === 'Unreleased' && !g.data.category));
const other = sortGamesDefault(allGames.filter((g) => g.data.category === 'Other'));
---
<BaseLayout title="Games" current="games" description="Released titles, works in progress, and game jam experiments from Blu Cat Dev.">
  <div class="page-header">
    <div class="section-label">Portfolio</div>
    <h1>Games</h1>
    <p>Released titles, works in progress, and game jam experiments.</p>
  </div>

  {released.length > 0 && (
    <section class="section" aria-labelledby="games-released-heading">
      <div class="section-label" id="games-released-heading">Released</div>
      <div class="games-grid">
        {released.map((game) => (
          <a class="game-card" href={`/games/${game.id}/`}>
            <div class="game-card-thumb" style={game.data.capsuleImage ? `background-image:url('${game.data.capsuleImage}');background-size:cover;background-position:center;` : ''}>
              {!game.data.capsuleImage && <span aria-hidden="true">🎮</span>}
            </div>
            <div class="game-card-body">
              <p class="game-card-genre">{game.data.genre}</p>
              <h3 class="game-card-title">{game.data.title}</h3>
              <p class="game-card-desc">{game.data.summary}</p>
            </div>
            <div class="game-card-footer">
              <div class="platform-pills">
                {game.data.platforms.map((p) => <span class="platform-pill">{p.toUpperCase()}</span>)}
              </div>
              <span class="tag tag-cyan">{game.data.status.toUpperCase()}</span>
              {game.data.category && <span class="tag tag-ember">{game.data.category.toUpperCase()}</span>}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  {inDevelopment.length > 0 && released.length > 0 && <hr class="divider" />}

  {inDevelopment.length > 0 && (
    <section class="section" aria-labelledby="games-indev-heading">
      <div class="section-label" id="games-indev-heading">In Development</div>
      <div class="games-grid">
        {inDevelopment.map((game) => (
          <a class="game-card" href={`/games/${game.id}/`}>
            <div class="game-card-thumb" style={game.data.capsuleImage ? `background-image:url('${game.data.capsuleImage}');background-size:cover;background-position:center;` : ''}>
              {!game.data.capsuleImage && <span aria-hidden="true">🌿</span>}
            </div>
            <div class="game-card-body">
              <p class="game-card-genre">{game.data.genre}</p>
              <h3 class="game-card-title">{game.data.title}</h3>
              <p class="game-card-desc">{game.data.summary}</p>
            </div>
            <div class="game-card-footer">
              <div class="platform-pills">
                {game.data.platforms.map((p) => <span class="platform-pill">{p.toUpperCase()}</span>)}
              </div>
              <span class="tag tag-cyan">{game.data.status.toUpperCase()}</span>
              {game.data.category && <span class="tag tag-ember">{game.data.category.toUpperCase()}</span>}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  {unreleased.length > 0 && (inDevelopment.length > 0 || released.length > 0) && <hr class="divider" />}

  {unreleased.length > 0 && (
    <section class="section" aria-labelledby="games-unreleased-heading">
      <div class="section-label" id="games-unreleased-heading">Unreleased</div>
      <div class="games-grid">
        {unreleased.map((game) => (
          <a class="game-card" href={`/games/${game.id}/`}>
            <div class="game-card-thumb" style={game.data.capsuleImage ? `background-image:url('${game.data.capsuleImage}');background-size:cover;background-position:center;` : ''}>
              {!game.data.capsuleImage && <span aria-hidden="true">🎮</span>}
            </div>
            <div class="game-card-body">
              <p class="game-card-genre">{game.data.genre}</p>
              <h3 class="game-card-title">{game.data.title}</h3>
              <p class="game-card-desc">{game.data.summary}</p>
            </div>
            <div class="game-card-footer">
              <div class="platform-pills">
                {game.data.platforms.map((p) => <span class="platform-pill">{p.toUpperCase()}</span>)}
              </div>
              <span class="tag tag-cyan">{game.data.status.toUpperCase()}</span>
              {game.data.category && <span class="tag tag-ember">{game.data.category.toUpperCase()}</span>}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  {other.length > 0 && (released.length > 0 || inDevelopment.length > 0 || unreleased.length > 0) && <hr class="divider" />}

  {other.length > 0 && (
    <section class="section" aria-labelledby="games-other-heading">
      <div class="section-label" id="games-other-heading">Other</div>
      <p style="margin-bottom:1.5rem;">Smaller projects, game jam entries, and experiments.</p>
      <div class="games-grid">
        {other.map((game) => (
          <a class="game-card" href={`/games/${game.id}/`}>
            <div class="game-card-thumb" style={game.data.capsuleImage ? `background-image:url('${game.data.capsuleImage}');background-size:cover;background-position:center;` : ''}>
              {!game.data.capsuleImage && <span aria-hidden="true">✨</span>}
            </div>
            <div class="game-card-body">
              <p class="game-card-genre">{game.data.genre}</p>
              <h3 class="game-card-title">{game.data.title}</h3>
              <p class="game-card-desc">{game.data.summary}</p>
            </div>
            <div class="game-card-footer">
              <div class="platform-pills">
                {game.data.platforms.map((p) => <span class="platform-pill">{p.toUpperCase()}</span>)}
              </div>
              <span class="tag tag-cyan">{game.data.status.toUpperCase()}</span>
              {game.data.category && <span class="tag tag-ember">{game.data.category.toUpperCase()}</span>}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  {allGames.length === 0 && (
    <section class="section">
      <div class="wip-placeholder">
        <h3>No games yet</h3>
        <p>Add a markdown file to <code>src/content/games/</code> to get started.</p>
      </div>
    </section>
  )}
</BaseLayout>
