---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allGames = (await getCollection('games', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Organize by status and category
const released = allGames.filter((g) => g.data.status === 'Released' && !g.data.category);
const inDevelopment = allGames.filter((g) => g.data.status === 'In Development' && !g.data.category);
const unreleased = allGames.filter((g) => g.data.status === 'Unreleased' && !g.data.category);
const jams = allGames.filter((g) => g.data.category === 'Jam');
const experiments = allGames.filter((g) => g.data.category === 'Experiment');

const renderGameCard = (game) => (
  <a class="game-card" href={`/games/${game.id}/`}>
    <div class="game-card-thumb" style={game.data.capsuleImage ? `background-image:url('${game.data.capsuleImage}');background-size:cover;background-position:center;` : ''}>
      {!game.data.capsuleImage && <span aria-hidden="true">🎮</span>}
      <span class="game-card-thumb-label">{game.data.status}</span>
    </div>
    <div class="game-card-body">
      <p class="game-card-genre">{game.data.genre}</p>
      <h3 class="game-card-title">{game.data.title}</h3>
      <p class="game-card-desc">{game.data.summary}</p>
    </div>
    <div class="game-card-footer">
      <div class="platform-pills">
        {game.data.platforms.map((p) => <span class="platform-pill">{p}</span>)}
      </div>
      <span class="tag tag-cyan">{game.data.status}</span>
    </div>
  </a>
);
---
<BaseLayout title="Games" current="games" description="Released titles, works in progress, and game jam experiments from Blu Cat Dev.">
  <div class="page-header">
    <div class="section-label">Portfolio</div>
    <h1>Games</h1>
    <p>Released titles, works in progress, and game jam experiments.</p>
  </div>

  {released.length > 0 && (
    <section class="section" aria-labelledby="games-released-heading">
      <div class="section-label" id="games-released-heading">Released</div>
      <div class="games-grid">
        {released.map(renderGameCard)}
      </div>
    </section>
  )}

  {inDevelopment.length > 0 && released.length > 0 && <hr class="divider" />}

  {inDevelopment.length > 0 && (
    <section class="section" aria-labelledby="games-indev-heading">
      <div class="section-label" id="games-indev-heading">In Development</div>
      <div class="games-grid">
        {inDevelopment.map(renderGameCard)}
      </div>
    </section>
  )}

  {unreleased.length > 0 && (inDevelopment.length > 0 || released.length > 0) && <hr class="divider" />}

  {unreleased.length > 0 && (
    <section class="section" aria-labelledby="games-unreleased-heading">
      <div class="section-label" id="games-unreleased-heading">Unreleased</div>
      <div class="games-grid">
        {unreleased.map(renderGameCard)}
      </div>
    </section>
  )}

  {jams.length > 0 && (released.length > 0 || inDevelopment.length > 0 || unreleased.length > 0) && <hr class="divider" />}

  {jams.length > 0 && (
    <section class="section" aria-labelledby="games-jams-heading">
      <div class="section-label" id="games-jams-heading">Game Jams</div>
      <p style="margin-bottom:1.5rem;">Quick builds, big ideas.</p>
      <div class="games-grid">
        {jams.map(renderGameCard)}
      </div>
    </section>
  )}

  {experiments.length > 0 && (released.length > 0 || inDevelopment.length > 0 || unreleased.length > 0 || jams.length > 0) && <hr class="divider" />}

  {experiments.length > 0 && (
    <section class="section" aria-labelledby="games-experiments-heading">
      <div class="section-label" id="games-experiments-heading">Experiments</div>
      <p style="margin-bottom:1.5rem;">Side projects and explorations.</p>
      <div class="games-grid">
        {experiments.map(renderGameCard)}
      </div>
    </section>
  )}

  {allGames.length === 0 && (
    <section class="section">
      <div class="wip-placeholder">
        <h3>No games yet</h3>
        <p>Add a markdown file to <code>src/content/games/</code> to get started.</p>
      </div>
    </section>
  )}
</BaseLayout>
