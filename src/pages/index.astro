---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const games = (await getCollection('games', ({ data }) => !data.draft));
const software = (await getCollection('software', ({ data }) => !data.draft));
const blogPosts = (await getCollection('blog', ({ data }) => !data.draft));
const poems = (await getCollection('poems', ({ data }) => !data.draft));

// Pick the highest-priority featured item across games & software for the hero.
const gamesFeatured = games.filter((item) => item.data.featured).map((item) => ({ item, type: 'games' as const }));
const softwareFeatured = software.filter((item) => item.data.featured).map((item) => ({ item, type: 'software' as const }));
const featuredEntry = [...gamesFeatured, ...softwareFeatured]
  .sort((a, b) => a.item.data.featuredOrder - b.item.data.featuredOrder)[0];

const featured = featuredEntry?.item;
const featuredType = featuredEntry?.type;

// Writing: featured first (by featuredOrder ascending), then by date (descending)
const allWritings = [
  ...blogPosts.map(p => ({ type: 'blog', item: p })),
  ...poems.map(p => ({ type: 'poem', item: p }))
];
const featuredWritings = allWritings.filter(w => w.item.data.featured).sort((a, b) => a.item.data.featuredOrder - b.item.data.featuredOrder);
const otherWritings = allWritings.filter(w => !w.item.data.featured).sort((a, b) => b.item.data.date.valueOf() - a.item.data.date.valueOf());
const selectedWritings = [...featuredWritings, ...otherWritings].slice(0, 3);

// Games: featured (ascending), released+standard (alphabetical), released+other (alphabetical)
const portfolioFeatured = games.filter(g => g.data.featured).sort((a, b) => a.data.featuredOrder - b.data.featuredOrder);
const portfolioReleasedStandard = games.filter(g => !g.data.featured && g.data.status === 'Released' && !g.data.category).sort((a, b) => a.data.title.localeCompare(b.data.title));
const portfolioReleasedOther = games.filter(g => !g.data.featured && g.data.status === 'Released' && g.data.category).sort((a, b) => a.data.title.localeCompare(b.data.title));
const recentGames = [...portfolioFeatured, ...portfolioReleasedStandard, ...portfolioReleasedOther].slice(0, 3);

// Software: featured (ascending), released+standard (alphabetical), released+other (alphabetical)
const softwareFeaturedList = software.filter(s => s.data.featured).sort((a, b) => a.data.featuredOrder - b.data.featuredOrder);
const softwareReleasedStandard = software.filter(s => !s.data.featured && s.data.status === 'Released' && !s.data.category).sort((a, b) => a.data.title.localeCompare(b.data.title));
const softwareReleasedOther = software.filter(s => !s.data.featured && s.data.status === 'Released' && s.data.category).sort((a, b) => a.data.title.localeCompare(b.data.title));
const recentSoftware = [...softwareFeaturedList, ...softwareReleasedStandard, ...softwareReleasedOther].slice(0, 3);
const hasSoftware = recentSoftware.length > 0;

const heroStyle = featured?.data.bgImage
  ? `--hero-image: url('${featured.data.bgImage}')`
  : undefined;
---
<BaseLayout title="Home" current="home">
  <!-- HERO -->
  <section class="hero" aria-label="Introduction" style={heroStyle}>
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="hero-content">
      <div>
        <p class="hero-eyebrow">Blu Cat Dev · Australia</p>
        <h1 class="hero-title" style="font-weight: 700;">
          <span class="accent-cyan">Games</span> and<br>
          <span class="accent-ember">stories</span> that<br>
          <em style="color: var(--text-primary);">linger...</em>
        </h1>
        <p class="hero-sub">
          Indie game developer and writer, making things part-time from Newcastle.
          Crafting worlds in Unity, telling stories in prose and code.
        </p>
        <div class="hero-ctas">
          <a class="btn btn-primary"
             href="https://store.steampowered.com/app/3304610/Elgem_TD/"
             target="_blank"
             rel="noopener noreferrer">
            Wishlist Elgem TD on Steam
          </a>
          <a class="btn btn-secondary" href="/games/">See My Games</a>
        </div>

        <div class="hero-newsletter">
          <span class="hero-newsletter-label">Get updates — dev logs, new releases, cat tax</span>
          <form
            class="hero-newsletter-row"
            action="https://blucatdev.us5.list-manage.com/subscribe/post?u=5002b517cebdf8d73021ea8e7&id=ffd8fc229b&f_id=00c8bfedf0"
            method="post"
            target="_blank"
            data-newsletter-form
          >
            <input
              class="hero-newsletter-input"
              type="email"
              name="EMAIL"
              placeholder="your@email.com"
              autocomplete="email"
              aria-label="Email address for newsletter"
              required
            />
            <!-- Honeypot field — must stay empty and hidden; Mailchimp uses it to catch bots -->
            <div aria-hidden="true" style="position:absolute;left:-5000px;">
              <input type="text" name="b_5002b517cebdf8d73021ea8e7_ffd8fc229b" tabindex="-1" value="" />
            </div>
            <button type="submit" class="hero-newsletter-btn">Subscribe</button>
          </form>
        </div>
      </div>

      <div class="hero-visual" aria-hidden="true">
        {featured && featuredType === 'games' && (
          <a class="hero-card" href={`/${featuredType}/${featured.id}/`} style="display:flex;gap:1rem;text-decoration:none;">
            <div style="flex:1;min-width:0;">
              <p class="hero-card-label">Featured Game</p>
              <p class="hero-card-title">{featured.data.title}</p>
              <p class="hero-card-desc" style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;">{featured.data.summary}</p>
              <div style="margin-top:0.75rem;display:flex;gap:0.5rem;flex-wrap:wrap;">
                <span class="tag tag-cyan">{featured.data.status.toUpperCase()}</span>
                {featured.data.platforms && featured.data.platforms[0] && <span class="tag tag-ember">{featured.data.platforms[0].toUpperCase()}</span>}
              </div>
            </div>
            {featured.data.capsuleImage && (
              <div style={`flex-shrink:0;width:100px;height:140px;border-radius:var(--radius-sm);overflow:hidden;background-size:cover;background-position:center;background-image:url('${featured.data.capsuleImage}');`}></div>
            )}
          </a>
        )}
        {selectedWritings.length > 0 && selectedWritings[0].type === 'blog' && (
          <a class="hero-card" href={`/writing/blog/${selectedWritings[0].item.id}/`} style="display:flex;gap:1rem;text-decoration:none;">
            <div style="flex:1;min-width:0;">
              <p class="hero-card-label">Latest from the Blog</p>
              <p class="hero-card-title">{selectedWritings[0].item.data.title}</p>
              <p class="hero-card-desc" style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;">{selectedWritings[0].item.data.summary}</p>
              <div style="margin-top:0.75rem;display:flex;gap:0.5rem;flex-wrap:wrap;">
                <span class="tag tag-cyan">BLOG</span>
                <span class="tag tag-silver">{selectedWritings[0].item.data.date.toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
              </div>
            </div>
            {selectedWritings[0].item.data.coverImage && (
              <div style={`flex-shrink:0;width:100px;height:140px;border-radius:var(--radius-sm);overflow:hidden;background-size:cover;background-position:center;background-image:url('${selectedWritings[0].item.data.coverImage}');`}></div>
            )}
          </a>
        )}
      </div>
    </div>
  </section>

  <!-- GAMES PREVIEW -->
  <hr class="divider" />
  <section class="section" aria-labelledby="home-games-heading">
    <div class="section-label">Portfolio</div>
    <h2 id="home-games-heading">Explore <em>fun</em> new worlds</h2>
    <p style="margin-bottom:2rem;max-width:500px;">A selection of released titles and works in progress.</p>
    <div class="games-grid">
      {recentGames.map((game) => (
        <a class="game-card" href={`/games/${game.id}/`}>
          <div class="game-card-thumb" style={game.data.capsuleImage ? `background-image:url('${game.data.capsuleImage}');background-size:cover;background-position:center;` : ''}>
            {!game.data.capsuleImage && <span aria-hidden="true">🎮</span>}
          </div>
          <div class="game-card-body">
            <p class="game-card-genre">{game.data.genre}</p>
            <h3 class="game-card-title">{game.data.title}</h3>
            <p class="game-card-desc">{game.data.summary}</p>
          </div>
          <div class="game-card-footer">
            <div class="platform-pills">
              {game.data.platforms.map((p) => <span class="platform-pill">{p.toUpperCase()}</span>)}
            </div>
            <span class="tag tag-cyan">{game.data.status.toUpperCase()}</span>
            {game.data.category && <span class="tag tag-ember">{game.data.category.toUpperCase()}</span>}
          </div>
        </a>
      ))}
    </div>
    <div style="margin-top:1.5rem;text-align:right;">
      <a class="btn btn-secondary btn-sm" href="/games/">View All Games →</a>
    </div>
  </section>

  <!-- SOFTWARE PREVIEW -->
  {hasSoftware && (
    <>
      <hr class="divider" />
      <section class="section" aria-labelledby="home-software-heading">
        <div class="section-label">Portfolio</div>
        <h2 id="home-software-heading">There's an <em>app</em> for that...</h2>
        <p style="margin-bottom:2rem;max-width:500px;">Tools and applications built outside of game projects.</p>
        <div class="games-grid">
          {recentSoftware.map((item) => (
            <a class="game-card" href={`/software/${item.id}/`}>
              <div class="game-card-thumb" style={item.data.capsuleImage ? `background-image:url('${item.data.capsuleImage}');background-size:cover;background-position:center;` : ''}>
                {!item.data.capsuleImage && <span aria-hidden="true">🛠️</span>}
              </div>
              <div class="game-card-body">
                <p class="game-card-genre">{item.data.genre}</p>
                <h3 class="game-card-title">{item.data.title}</h3>
                <p class="game-card-desc">{item.data.summary}</p>
              </div>
              <div class="game-card-footer">
                <div class="platform-pills">
                  {item.data.platforms.map((p) => <span class="platform-pill">{p.toUpperCase()}</span>)}
                </div>
                <span class="tag tag-cyan">{item.data.status.toUpperCase()}</span>
                {item.data.category && <span class="tag tag-ember">{item.data.category.toUpperCase()}</span>}
              </div>
            </a>
          ))}
        </div>
        <div style="margin-top:1.5rem;text-align:right;">
          <a class="btn btn-secondary btn-sm" href="/software/">View All Software →</a>
        </div>
      </section>
    </>
  )}

  <!-- QUICK ABOUT -->
  <hr class="divider" />
  <section class="section" aria-labelledby="home-about-heading">
    <div class="section-label">About</div>
    <div class="quick-about">
      <div class="quick-about-avatar" aria-hidden="true">
        <img src="/assets/images/avatar.png" alt="Profile photo" onerror="this.outerHTML='🐱'" />
      </div>
      <div>
        <p class="quick-about-text">
          <strong>Software engineer, indie game dev, writer, and cat &amp; lizard lady</strong>
          based in Newcastle, NSW. Making games part-time alongside a career in software engineering,
          a 15-year D&amp;D habit, and a bearded dragon named Krispy who supervises most
          development decisions.
        </p>
        <div style="margin-top:1rem;">
          <a class="btn btn-secondary btn-sm" href="/about/">Learn More About Me →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOG PREVIEW -->
  <hr class="divider" />
  <section class="section" aria-labelledby="home-blog-heading">
    <div class="section-label">Writing</div>
    <h2 id="home-blog-heading"><em>Words</em> of fact and fiction</h2>
    <p style="margin-bottom:2rem;max-width:500px;">Dev logs, game design thoughts, honest notes from a part-time indie, and selected poetry.</p>
    <div class="blog-grid">
      {selectedWritings.map((writing) => {
        const item = writing.item;
        if (writing.type === 'blog') {
          return (
            <a class="blog-card" href={`/writing/blog/${item.id}/`}>
              {item.data.tags[0] && <span class="tag tag-silver" style="margin-bottom:0.75rem;">{item.data.tags[0].toUpperCase()}</span>}
              <h3 class="blog-card-title">{item.data.title}</h3>
              <p class="blog-card-excerpt">{item.data.summary}</p>
              <div class="blog-card-meta">
                <span style="color: var(--text-dim);">{item.data.date.toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
                <span class="tag tag-cyan">BLOG</span>
              </div>
            </a>
          );
        } else {
          return (
            <a class="blog-card" href={`/writing/poems/${item.id}/`}>
              <h3 class="blog-card-title" style="margin-bottom: 0.75rem;">{item.data.title}</h3>
              <p class="blog-card-excerpt">{item.data.summary}</p>
              <div class="blog-card-meta">
                <span style="color: var(--text-dim);">{item.data.date.toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
                <span class="tag tag-ember">POETRY</span>
              </div>
            </a>
          );
        }
      })}
    </div>
    <div style="margin-top:1.5rem;text-align:right;">
      <a class="btn btn-secondary btn-sm" href="/writing/">View All Writing →</a>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <div class="newsletter-section">
    <div class="newsletter-inner">
      <div class="newsletter-text">
        <h2>Stay in the <em>loop</em></h2>
        <p>Dev updates, new writing, game releases, and the occasional cat tax. No spam, no pressure.</p>
      </div>
      <div>
        <form
          class="newsletter-form"
          action="https://blucatdev.us5.list-manage.com/subscribe/post?u=5002b517cebdf8d73021ea8e7&id=ffd8fc229b&f_id=00c8bfedf0"
          method="post"
          target="_blank"
          data-newsletter-form
        >
          <input
            class="newsletter-input"
            type="email"
            name="EMAIL"
            placeholder="your@email.com"
            autocomplete="email"
            aria-label="Email address"
            required
          />
          <!-- Honeypot field — must stay empty and hidden; Mailchimp uses it to catch bots -->
          <div aria-hidden="true" style="position:absolute;left:-5000px;">
            <input type="text" name="b_5002b517cebdf8d73021ea8e7_ffd8fc229b" tabindex="-1" value="" />
          </div>
          <button type="submit" class="btn btn-primary">Subscribe</button>
        </form>
        <p class="newsletter-note">No spam. Unsubscribe any time.</p>
      </div>
    </div>
  </div>
</BaseLayout>
